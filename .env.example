# copy this to .env and fill in your key
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash
LOG_LEVEL=INFO

# the assistant treats this date as "today" so tomorrow/this-month answers
# stay stable while you demo. leave it on the mock-data window.
TODAY=2025-11-10

# leave API_KEY empty to disable auth. set it to require an X-API-Key header.
API_KEY=
